# Firebase / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=C:/path/to/serviceAccountKey.json
FIRESTORE_COLLECTION=benchmark_results
ENABLE_FIRESTORE=true
FIRESTORE_REQUIRED=false

# Model / Ollama
MODEL_NAME=llama3
OLLAMA_BASE_URL=http://127.0.0.1:11434
MODEL_TEMPERATURE=0
MODEL_SEED=42
MODEL_NUM_PREDICT=1024
MODEL_NUM_CTX=2048
MODEL_TOP_K=10
MODEL_TOP_P=0.9
MODEL_REPEAT_PENALTY=1.1

# Long-answer safeguard
MODEL_AUTO_CONTINUE_ON_LENGTH=true
MODEL_MAX_CONTINUE_ROUNDS=2
MODEL_CONTINUATION_TAIL_CHARS=1200
