# Firebase / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=C:/path/to/serviceAccountKey.json
FIRESTORE_COLLECTION=benchmark_results
ENABLE_FIRESTORE=true
FIRESTORE_REQUIRED=false

# Model / Ollama
MODEL_NAME=llama3
OLLAMA_BASE_URL=http://127.0.0.1:11434
MODEL_TEMPERATURE=0
MODEL_SEED=42
MODEL_NUM_PREDICT=2048
MODEL_NUM_CTX=8192
MODEL_TOP_K=10
MODEL_TOP_P=0.9
MODEL_REPEAT_PENALTY=1.1

# Long-answer safeguard
MODEL_AUTO_CONTINUE_ON_LENGTH=true
MODEL_MAX_CONTINUE_ROUNDS=4
MODEL_CONTINUATION_TAIL_CHARS=1200

# Verifier-retry safeguard
MODEL_VERIFIER_RETRY_ENABLED=true
MODEL_VERIFIER_RETRY_ATTEMPTS=1
MODEL_VERIFIER_NUM_PREDICT=256
MODEL_VERIFIER_MIN_CHARS=48
MODEL_VERIFIER_REQUIRE_FINAL_ANSWER=true

# Few-shot control
FEW_SHOT_MIN_EXAMPLES=1
FEW_SHOT_MAX_EXAMPLES=4
FEW_SHOT_MEDIUM_EXAMPLES=2
FEW_SHOT_HARD_EXAMPLES=4
