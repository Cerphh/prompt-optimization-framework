{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-optimization-framework/schema/example-bank.schema.json",
  "title": "Prompt Optimization Example Bank",
  "description": "Subject-organized few-shot example bank with backward-compatible optional metadata fields.",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "oneOf": [
      {
        "$ref": "#/$defs/exampleList"
      },
      {
        "$ref": "#/$defs/difficultyMap"
      }
    ]
  },
  "$defs": {
    "exampleList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exampleEntry"
      }
    },
    "difficultyMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/exampleList"
      }
    },
    "stringOrStringArray": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "formatValue": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "exampleEntry": {
      "type": "object",
      "required": [
        "problem"
      ],
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "solution": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "concept": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "format": {
          "oneOf": [
            {
              "$ref": "#/$defs/stringOrStringArray"
            },
            {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "$ref": "#/$defs/formatValue"
              }
            }
          ]
        },
        "difficulty": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "number",
              "minimum": 1
            }
          ]
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "anchor_priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "solution"
          ]
        },
        {
          "required": [
            "answer"
          ]
        }
      ]
    }
  }
}
